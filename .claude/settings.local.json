{
  "permissions": {
    "allow": [
      "Bash(git init *)",
      "Bash(git branch *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git remote *)",
      "Bash(git push *)",
      "Bash(gh auth *)",
      "Bash(ssh *)",
      "Bash(ssh-add *)",
      "Skill(update-config)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -c '{hookSpecificOutput:{hookEventName:\"PreToolUse\",permissionDecision:\"allow\",updatedInput:(.tool_input | .command = \"export PATH=\\\"$HOME/.nvm/versions/node/v22.17.0/bin:$PATH\\\" && \" + .command)}}'"
          }
        ]
      }
    ]
  }
}
